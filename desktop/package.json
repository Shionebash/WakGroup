{
    "name": "wakgroup-desktop",
    "version": "1.0.5",
    "author": "Shionebash",
    "description": "WakGroup Desktop Overlay Client",
    "homepage": "./",
    "scripts": {
        "dev": "parcel build src/index.html --dist-dir dist-renderer --no-optimize --public-url ./ && electron electron/main.js",
        "build": "parcel build src/index.html --dist-dir dist-renderer --public-url ./ && electron-builder",
        "release": "parcel build src/index.html --dist-dir dist-renderer --public-url ./ && electron-builder --publish always",
        "electron": "electron electron/main.js"
    },
    "dependencies": {
        "axios": "^1.6.8",
        "electron-updater": "^6.3.9",
        "react": "^18.3.1",
        "react-dom": "^18.3.1",
        "socket.io-client": "^4.7.4"
    },
    "devDependencies": {
        "@types/react": "^18.3.1",
        "@types/react-dom": "^18.3.0",
        "concurrently": "^8.2.2",
        "electron": "^41.0.2",
        "electron-builder": "^26.8.1",
        "electron-is-dev": "^2.0.0",
        "parcel": "^2.16.4",
        "wait-on": "^7.2.0"
    },
    "build": {
        "appId": "com.wakgroup.desktop",
        "productName": "WakGroup",
        "artifactName": "WakGroup-Setup.${ext}",
        "directories": {
            "output": "release"
        },
        "publish": [
            {
                "provider": "github",
                "owner": "Shionebash",
                "repo": "WakGroup",
                "releaseType": "release"
            }
        ],
        "win": {
            "target": "nsis",
            "icon": "assets/icon.ico"
        },
        "files": [
            "dist-renderer/**",
            "electron/**",
            "assets/**"
        ],
        "nsis": {
            "oneClick": false,
            "allowToChangeInstallationDirectory": true
        },
        "extraMetadata": {
            "main": "electron/main.js"
        }
    },
    "source": "src/index.html"
}


